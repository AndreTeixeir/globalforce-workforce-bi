# Banco de dados MySQL
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_HOST=localhost
DB_PORT=3306
DB_NAME=workforce_bi

# E-mail (Gmail recomendado)
# Para Gmail: ative verificação em 2 etapas e gere uma "Senha de App" em:
# https://myaccount.google.com/apppasswords
SENDER_EMAIL=seu-email@gmail.com
SENDER_PASSWORD=sua-senha-de-app
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# WhatsApp via CallMeBot (gratuito)
# 1. Adicione o contato +34 613 01 49 37 no seu WhatsApp
# 2. Envie a mensagem: I allow callmebot to send me messages
# 3. Você receberá sua API key em segundos
CALLMEBOT_API_KEY=sua_api_key_aqui
